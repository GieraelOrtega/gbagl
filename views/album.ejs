<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="content-page">
  <div class="container">
    <header class="page-header">
      <p><a href="/albums">Back to albums</a></p>
      <h1 class="page-header__title"><%= album.title %></h1>
      <p class="page-header__subtitle"><%= album.description %></p>
    </header>

    <% if (message) { %><div class="alert alert--success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>
    <% if (!canEdit && !offlineSnapshot) { %>
      <div class="read-only-note">View-only mode: sign in from Settings to add, edit, or reorder photos.</div>
    <% } %>

    <% if (canEdit) { %>
      <div class="editor-grid">
        <details class="card editor-panel">
          <summary>Upload a protected photo</summary>
          <form action="/albums/photos/upload" method="post"
                enctype="multipart/form-data" class="admin-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="form-group">
              <label class="form-label" for="new-photo-file">JPEG, PNG, or WebP</label>
              <input class="form-input" id="new-photo-file" name="photo" type="file"
                     accept="image/jpeg,image/png,image/webp" required />
            </div>
            <%- include('partials/photo-fields', {
              photo: {
                album_id: album.id,
                milestone_id: null,
                caption: '',
                photo_date: ''
              },
              prefix: 'new-photo',
              fixedAlbum: true
            }) %>
            <button type="submit" class="btn btn--primary">Upload photo</button>
          </form>
        </details>

        <details class="card editor-panel">
          <summary>Link an existing site image</summary>
          <form action="/albums/photos/existing" method="post" class="admin-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="form-group">
              <label class="form-label" for="existing-image">Image path under /images</label>
              <input class="form-input" id="existing-image" name="existing_image"
                     placeholder="/images/photo.jpg" maxlength="255" required />
            </div>
            <%- include('partials/photo-fields', {
              photo: {
                album_id: album.id,
                milestone_id: null,
                caption: '',
                photo_date: ''
              },
              prefix: 'existing-photo',
              fixedAlbum: true
            }) %>
            <button type="submit" class="btn btn--primary">Link photo</button>
          </form>
        </details>
      </div>
      <% if (photos.length > 1) { %>
        <%- include('partials/reorder-toolbar', { group: 'photos', label: 'photos' }) %>
      <% } %>
    <% } %>

    <div class="photo-grid" data-reorder-group="photos"
         data-reorder-url="/albums/<%= album.id %>/photos/reorder">
      <% photos.forEach((photo) => { %>
        <figure class="card photo-card" data-reorder-item data-reorder-id="<%= photo.id %>">
          <% if (canEdit) { %>
            <%- include('partials/reorder-controls', {
              label: `photo ${photo.caption || photo.id}`
            }) %>
          <% } %>
          <img src="/albums/photos/<%= photo.id %>/content"
               alt="<%= photo.caption || album.title %>" loading="lazy" />
          <figcaption>
            <% if (photo.caption) { %><p><%= photo.caption %></p><% } %>
            <% if (photo.photo_date) { %><small><%= photo.photo_date %></small><% } %>
            <% if (photo.milestone_title) { %><small>Timeline: <%= photo.milestone_title %></small><% } %>
            <% if (canEdit) { %>
              <details class="item-editor">
                <summary>Edit photo details</summary>
                <form action="/albums/photos/<%= photo.id %>" method="post" class="admin-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <%- include('partials/photo-fields', {
                    photo,
                    prefix: `photo-${photo.id}`,
                    fixedAlbum: false
                  }) %>
                  <button type="submit" class="btn btn--primary">Save photo details</button>
                </form>
                <form action="/albums/photos/<%= photo.id %>/delete" method="post"
                      class="admin-danger" data-confirm="Delete this photo?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="album_id" value="<%= album.id %>" />
                  <button type="submit" class="btn btn--outline">Delete photo</button>
                </form>
              </details>
            <% } %>
          </figcaption>
        </figure>
      <% }) %>
    </div>
    <% if (photos.length === 0) { %>
      <div class="empty-state">This album has no photos yet.</div>
    <% } %>
  </div>
</main>
<%- include('partials/footer') %>
