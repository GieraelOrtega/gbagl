<%- include('partials/head') %>

<main class="gate">
  <div class="gate__shell">
    <p class="gate__eyebrow">💕 A little question before we begin</p>
    <h1 class="gate__title">When did our story begin?</h1>
    <p class="gate__subtitle">Enter the date to unlock our little corner of the internet.</p>

    <% if (message) { %>
      <div class="gate__message gate__message--<%= messageType %>"><%= message %></div>
    <% } %>

    <form id="unlockForm" class="gate__form" action="/unlock" method="post">
      <label for="anniversaryDate" class="gate__label">Our anniversary date</label>
      <input
        id="anniversaryDate"
        name="anniversaryDate"
        class="gate__input"
        type="date"
        required
      />
      <button id="unlockButton" type="submit" class="btn btn--primary btn--full">Unlock ✨</button>
    </form>
  </div>

  <div class="gate-hearts" id="gateHearts" aria-hidden="true"></div>
</main>

<script>
  window.GATE_TRIGGER_ANIMATION = <%= triggerAnimation ? 'true' : 'false' %>;
</script>
<script src="/js/gate.js"></script>
</body>
</html>
