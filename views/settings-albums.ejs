<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="admin-page"><div class="container">
  <%- include('partials/settings-header', {
    heading: 'Manage Albums & Photos',
    subtitle: 'Uploads stay outside public static paths. Existing deployment images can be linked by /images/basename.'
  }) %>
  <section class="card admin-section">
    <h2 class="card__title">Add album</h2>
    <form action="/settings/content/albums" method="post" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <%- include('partials/album-fields', {
        album: { title: '', description: '', album_date: '', display_order: albums.length },
        prefix: 'new-album'
      }) %>
      <button class="btn btn--primary" type="submit">Add album</button>
    </form>
  </section>
  <% if (albums.length > 0) { %>
    <section class="admin-grid">
      <article class="card">
        <h2 class="card__title">Upload protected photo</h2>
        <form action="/settings/content/albums/photos/upload" method="post" enctype="multipart/form-data" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="form-group">
            <label class="form-label" for="new-photo-file">JPEG, PNG, or WebP (maximum configured size)</label>
            <input class="form-input" id="new-photo-file" name="photo" type="file"
                   accept="image/jpeg,image/png,image/webp" required />
          </div>
          <%- include('partials/photo-fields', {
            photo: { album_id: albums[0].id, milestone_id: null, caption: '', photo_date: '', display_order: 0 },
            prefix: 'new-photo'
          }) %>
          <button class="btn btn--primary" type="submit">Upload photo</button>
        </form>
      </article>
      <article class="card">
        <h2 class="card__title">Link deployment-local image</h2>
        <form action="/settings/content/albums/photos/existing" method="post" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="form-group">
            <label class="form-label" for="existing-image">Path under /images</label>
            <input class="form-input" id="existing-image" name="existing_image"
                   placeholder="/images/private-photo.jpg" maxlength="255" required />
          </div>
          <%- include('partials/photo-fields', {
            photo: { album_id: albums[0].id, milestone_id: null, caption: '', photo_date: '', display_order: 0 },
            prefix: 'existing-photo'
          }) %>
          <button class="btn btn--primary" type="submit">Link photo</button>
        </form>
      </article>
    </section>
  <% } %>
  <section class="admin-stack">
    <% albums.forEach((album) => { %>
      <article class="card">
        <form action="/settings/content/albums/<%= album.id %>" method="post" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <%- include('partials/album-fields', { album, prefix: `album-${album.id}` }) %>
          <button class="btn btn--primary" type="submit">Update album</button>
        </form>
        <form action="/settings/content/albums/<%= album.id %>/delete" method="post" class="admin-danger">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn--outline" type="submit">Delete album and photos</button>
        </form>
      </article>
    <% }) %>
  </section>
  <section class="admin-stack">
    <h2 class="section-title section-title--left">Photo details and ordering</h2>
    <% photos.forEach((photo) => { %>
      <article class="card admin-photo-row">
        <img src="/albums/photos/<%= photo.id %>/content" alt="" loading="lazy" />
        <div>
          <form action="/settings/content/albums/photos/<%= photo.id %>" method="post" class="admin-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <%- include('partials/photo-fields', { photo, prefix: `photo-${photo.id}` }) %>
            <button class="btn btn--primary" type="submit">Update photo</button>
          </form>
          <form action="/settings/content/albums/photos/<%= photo.id %>/delete" method="post" class="admin-danger">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn btn--outline" type="submit">Delete photo</button>
          </form>
        </div>
      </article>
    <% }) %>
  </section>
  <% if (!dbError && albums.length === 0) { %><div class="empty-state">Create an album before adding photos.</div><% } %>
</div></main>
<%- include('partials/footer') %>
