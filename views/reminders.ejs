<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="content-page">
  <div class="container">
    <header class="page-header">
      <h1 class="page-header__title">Events &amp; Reminders</h1>
      <p class="page-header__subtitle">Times shown in <%= timeZone %>.</p>
    </header>
    <% if (message) { %><div class="alert alert--success"><%= message %></div><% } %>
    <% if (dbError) { %><div class="alert alert--warning"><%= dbError %></div><% } %>
    <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>
    <% if (!canEdit && !offlineSnapshot) { %>
      <div class="read-only-note">View-only mode: sign in from Settings to manage or dismiss events.</div>
    <% } %>
    <% if (!dbError && !offlineSnapshot) { %>
      <section class="card notification-panel">
        <h2 class="card__title">While-this-page-is-open reminders</h2>
        <p>Browser alerts work only while GBAGL is open. They are not background push notifications.</p>
        <button class="btn btn--primary" id="enableNotifications" type="button">Enable browser reminders</button>
        <p id="notificationStatus" role="status"></p>
      </section>
    <% } %>
    <% if (!dbError && canEdit) { %>
      <details class="card editor-panel">
        <summary>Add an event</summary>
        <form action="/reminders" method="post" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <%- include('partials/event-fields', {
            event: {
              title: '',
              event_input: '',
              reminder_input: '',
              notes: '',
              is_completed: false
            },
            prefix: 'new-event'
          }) %>
          <button type="submit" class="btn btn--primary">Add event</button>
        </form>
      </details>
      <% if (upcoming.length + past.length > 1) { %>
        <%- include('partials/reorder-toolbar', { group: 'events', label: 'events' }) %>
      <% } %>
    <% } %>
    <section>
      <h2 class="section-title section-title--left">Upcoming</h2>
      <div class="hub-grid" data-reorder-group="events" data-reorder-url="/reminders/reorder">
        <% upcoming.forEach((event) => { %>
          <article class="card hub-card" id="event-<%= event.id %>"
                   data-reorder-item data-reorder-id="<%= event.id %>">
            <% if (canEdit) { %>
              <%- include('partials/reorder-controls', { label: `event ${event.title}` }) %>
            <% } %>
            <h3 class="card__title"><%= event.title %></h3>
            <p><strong><%= formatDateTime(event.event_at, timeZone) %></strong></p>
            <% if (event.notes) { %><p><%= event.notes %></p><% } %>
            <% if (!offlineSnapshot) { %><a class="btn btn--outline" href="/reminders/<%= event.id %>.ics">Add to calendar</a><% } %>
            <% if (canEdit && event.reminder_at && !event.reminder_dismissed) { %>
              <form action="/reminders/<%= event.id %>/dismiss" method="post">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button class="btn btn--outline" type="submit">Dismiss browser reminder</button>
              </form>
            <% } %>
            <% if (canEdit) { %>
              <details class="item-editor">
                <summary>Edit event</summary>
                <form action="/reminders/<%= event.id %>" method="post" class="admin-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <%- include('partials/event-fields', {
                    event,
                    prefix: `event-${event.id}`
                  }) %>
                  <button type="submit" class="btn btn--primary">Save event</button>
                </form>
                <form action="/reminders/<%= event.id %>/delete" method="post"
                      class="admin-danger" data-confirm="Delete this event?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn--outline">Delete event</button>
                </form>
              </details>
            <% } %>
          </article>
        <% }) %>
      </div>
      <% if (upcoming.length === 0) { %><div class="empty-state">No upcoming events.</div><% } %>
    </section>
    <section>
      <h2 class="section-title section-title--left">Past</h2>
      <div class="compact-list" data-reorder-group="events" data-reorder-url="/reminders/reorder">
        <% past.forEach((event) => { %>
          <article class="card" id="event-<%= event.id %>"
                   data-reorder-item data-reorder-id="<%= event.id %>">
            <% if (canEdit) { %>
              <%- include('partials/reorder-controls', { label: `event ${event.title}` }) %>
            <% } %>
            <h3 class="card__title"><%= event.title %></h3>
            <p><%= formatDateTime(event.event_at, timeZone) %></p>
            <% if (event.notes) { %><p><%= event.notes %></p><% } %>
            <% if (canEdit) { %>
              <details class="item-editor">
                <summary>Edit event</summary>
                <form action="/reminders/<%= event.id %>" method="post" class="admin-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <%- include('partials/event-fields', {
                    event,
                    prefix: `past-event-${event.id}`
                  }) %>
                  <button type="submit" class="btn btn--primary">Save event</button>
                </form>
                <form action="/reminders/<%= event.id %>/delete" method="post"
                      class="admin-danger" data-confirm="Delete this event?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn--outline">Delete event</button>
                </form>
              </details>
            <% } %>
          </article>
        <% }) %>
      </div>
      <% if (past.length === 0) { %><div class="empty-state">No past events.</div><% } %>
    </section>
  </div>
</main>
<%- include('partials/footer') %>
