<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="admin-page"><div class="container">
  <%- include('partials/admin-header', {
    heading: 'Manage Journal',
    subtitle: 'Entries can stand alone or appear beside a timeline milestone.'
  }) %>
  <section class="card admin-section">
    <h2 class="card__title">Add journal entry</h2>
    <form action="/admin/journals" method="post" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <%- include('partials/journal-fields', {
        entry: { title: '', body: '', entry_date: '', milestone_id: null },
        prefix: 'new-journal'
      }) %>
      <button class="btn btn--primary" type="submit">Add entry</button>
    </form>
  </section>
  <section class="admin-stack">
    <% entries.forEach((entry) => { %>
      <article class="card">
        <form action="/admin/journals/<%= entry.id %>" method="post" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <%- include('partials/journal-fields', { entry, prefix: `journal-${entry.id}` }) %>
          <button class="btn btn--primary" type="submit">Update entry</button>
        </form>
        <form action="/admin/journals/<%= entry.id %>/delete" method="post" class="admin-danger">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn--outline" type="submit">Delete entry</button>
        </form>
      </article>
    <% }) %>
  </section>
  <% if (!dbError && entries.length === 0) { %><div class="empty-state">No journal entries yet.</div><% } %>
</div></main>
<%- include('partials/footer') %>
