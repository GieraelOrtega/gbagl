<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="admin-page"><div class="container">
  <%- include('partials/settings-header', {
    heading: 'Manage Bucket List',
    subtitle: 'Add, edit, and organize shared dreams.'
  }) %>
  <section class="card admin-section">
    <h2 class="card__title">Add bucket item</h2>
    <form action="/settings/content/bucket" method="post" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <%- include('partials/bucket-fields', {
        item: { title: '', description: '', category: 'other', target_date: '' },
        prefix: 'new-bucket'
      }) %>
      <button class="btn btn--primary" type="submit">Add item</button>
    </form>
  </section>
  <section class="admin-stack">
    <% items.forEach((item) => { %>
      <article class="card">
        <form action="/settings/content/bucket/<%= item.id %>" method="post" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <%- include('partials/bucket-fields', { item, prefix: `bucket-${item.id}` }) %>
          <button class="btn btn--primary" type="submit">Update item</button>
        </form>
        <form action="/settings/content/bucket/<%= item.id %>/delete" method="post" class="admin-danger">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn--outline" type="submit">Delete item</button>
        </form>
      </article>
    <% }) %>
  </section>
  <% if (!dbError && items.length === 0) { %><div class="empty-state">No bucket items yet.</div><% } %>
</div></main>
<%- include('partials/footer') %>
