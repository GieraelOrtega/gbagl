<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="page-timeline">
  <div class="container">

    <header class="page-header">
      <h1 class="page-header__title">Our Timeline 📖</h1>
      <p class="page-header__subtitle">
        Every milestone, every first, every memory — our story from the very beginning. 💕
      </p>
    </header>

    <!-- ── Timeline ───────────────────────────────────────── -->
    <div class="timeline">
      <% milestones.forEach((milestone, index) => { %>
      <div class="timeline__item <%= index % 2 === 0 ? 'timeline__item--left' : 'timeline__item--right' %>">

        <div class="timeline__connector">
          <div class="timeline__dot"><span><%= milestone.emoji %></span></div>
        </div>

        <article class="timeline__card card">
          <div class="timeline__date"><%= milestone.date %></div>
          <h2 class="timeline__title"><%= milestone.title %></h2>
          <p class="timeline__description"><%= milestone.description %></p>
          <% if (milestone.link_url) { %>
            <p><a href="<%= milestone.link_url %>" rel="noopener noreferrer">Visit memory</a></p>
          <% } %>

          <% if (milestone.photo) { %>
            <!-- 📸 Photo for this milestone -->
            <img src="/<%= milestone.photo %>"
                 alt="<%= milestone.title %>"
                 class="timeline__photo"
                 loading="lazy" />
          <% } else { %>
            <div class="timeline__photo-placeholder">
              <span>📸</span>
              <small>No photo for this memory yet</small>
            </div>
          <% } %>
        </article>

      </div>
      <% }) %>
    </div>
    <!-- end timeline -->

  </div>
</main>

<%- include('partials/footer') %>
