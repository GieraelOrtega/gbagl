<div class="reorder-controls" data-reorder-controls hidden>
  <button type="button" class="drag-handle" data-drag-handle
          aria-label="Drag <%= label %> to a new position">Drag</button>
  <button type="button" class="reorder-step" data-move-direction="up"
          aria-label="Move <%= label %> up">Up</button>
  <button type="button" class="reorder-step" data-move-direction="down"
          aria-label="Move <%= label %> down">Down</button>
</div>
