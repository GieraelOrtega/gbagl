<div class="reorder-toolbar">
  <button type="button" class="btn btn--outline"
          data-reorder-toggle="<%= group %>"
          data-reorder-label="Reorder <%= label %>"
          aria-pressed="false">
    Reorder <%= label %>
  </button>
  <p class="reorder-status" data-reorder-status="<%= group %>" role="status"></p>
</div>
