<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="admin-page">
  <div class="container admin-login">
    <section class="card" aria-labelledby="admin-login-title">
      <h1 class="card__title" id="admin-login-title">Private admin sign in</h1>
      <p class="admin-help">Site access does not grant administrative access.</p>
      <% if (error) { %>
        <div class="alert alert--error" role="alert"><%= error %></div>
      <% } %>
      <form action="/admin/login" method="post" class="admin-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label for="admin-password" class="form-label">Admin passphrase</label>
          <input id="admin-password" name="password" type="password"
                 class="form-input" autocomplete="current-password" required />
        </div>
        <button type="submit" class="btn btn--primary">Sign in</button>
      </form>
    </section>
  </div>
</main>

<%- include('partials/footer') %>
