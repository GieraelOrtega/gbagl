<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="admin-page"><div class="container">
  <%- include('partials/settings-header', {
    heading: 'Manage Events',
    subtitle: `Enter times in ${timeZone}. Stored reminder times are ready for a later service worker.`
  }) %>
  <section class="card admin-section">
    <h2 class="card__title">Add event</h2>
    <form action="/settings/content/events" method="post" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <%- include('partials/event-fields', {
        event: { title: '', event_input: '', reminder_input: '', notes: '', is_completed: false },
        prefix: 'new-event'
      }) %>
      <button class="btn btn--primary" type="submit">Add event</button>
    </form>
  </section>
  <section class="admin-stack">
    <% events.forEach((event) => { %>
      <article class="card">
        <form action="/settings/content/events/<%= event.id %>" method="post" class="admin-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <%- include('partials/event-fields', { event, prefix: `event-${event.id}` }) %>
          <button class="btn btn--primary" type="submit">Update event</button>
        </form>
        <form action="/settings/content/events/<%= event.id %>/delete" method="post" class="admin-danger">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn--outline" type="submit">Delete event</button>
        </form>
      </article>
    <% }) %>
  </section>
  <% if (!dbError && events.length === 0) { %><div class="empty-state">No events yet.</div><% } %>
</div></main>
<%- include('partials/footer') %>
