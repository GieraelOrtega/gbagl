<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="admin-page">
  <div class="container">
    <header class="page-header admin-header">
      <div>
        <h1 class="page-header__title">Admin Dashboard</h1>
        <p class="page-header__subtitle">Manage private site content and backups.</p>
      </div>
      <form action="/admin/logout" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="btn btn--outline">Admin logout</button>
      </form>
    </header>

    <% if (message) { %><div class="alert alert--success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>
    <% if (dbError) { %><div class="alert alert--warning"><%= dbError %></div><% } %>

    <nav class="admin-tools" aria-label="Layer 2 content management">
      <a class="btn btn--outline" href="/admin/bucket">Bucket items</a>
      <a class="btn btn--outline" href="/admin/events">Events</a>
      <a class="btn btn--outline" href="/admin/albums">Albums & photos</a>
      <a class="btn btn--outline" href="/admin/journals">Journal entries</a>
      <a class="btn btn--outline" href="/admin/exports">Keepsake exports</a>
    </nav>

    <section class="card admin-section" id="site-settings">
      <h2 class="card__title">Site settings</h2>
      <form action="/admin/settings" method="post" class="admin-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="admin-grid">
          <div class="form-group">
            <label class="form-label" for="partner-one">First partner display name</label>
            <input class="form-input" id="partner-one" name="partner_one_name"
                   maxlength="80" value="<%= settings.partner_one_name || '' %>" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="partner-two">Second partner display name</label>
            <input class="form-input" id="partner-two" name="partner_two_name"
                   maxlength="80" value="<%= settings.partner_two_name || '' %>" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="anniversary">Anniversary date</label>
            <input class="form-input" id="anniversary" name="anniversary_date" type="date"
                   value="<%= settings.anniversary_date || '' %>" />
          </div>
          <div class="form-group">
            <label class="form-label" for="timezone">IANA timezone</label>
            <input class="form-input" id="timezone" name="timezone" maxlength="100"
                   value="<%= settings.timezone || 'UTC' %>" required />
          </div>
        </div>
        <button type="submit" class="btn btn--primary">Save settings</button>
      </form>
    </section>

    <section class="card admin-section">
      <h2 class="card__title">Add timeline milestone</h2>
      <form action="/admin/timeline" method="post" class="admin-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <%- include('partials/milestone-fields', { milestone: {
          display_order: milestones.length,
          date: '',
          title: '',
          description: '',
          emoji: '',
          photo: '',
          link_url: ''
        }, prefix: 'new' }) %>
        <button type="submit" class="btn btn--primary">Add milestone</button>
      </form>
    </section>

    <section class="admin-section">
      <h2 class="section-title section-title--left">Timeline milestones</h2>
      <div class="admin-stack">
        <% milestones.forEach((milestone) => { %>
          <article class="card">
            <form action="/admin/timeline/<%= milestone.id %>" method="post" class="admin-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <%- include('partials/milestone-fields', {
                milestone,
                prefix: `milestone-${milestone.id}`
              }) %>
              <button type="submit" class="btn btn--primary">Update milestone</button>
            </form>
            <form action="/admin/timeline/<%= milestone.id %>/delete" method="post"
                  class="admin-danger">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn--outline">Delete milestone</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="admin-section">
      <h2 class="section-title section-title--left">Date ideas</h2>
      <div class="admin-stack">
        <% ideas.forEach((idea) => { %>
          <article class="card admin-row">
            <div>
              <strong><%= idea.vibe %> · <%= idea.location %> · <%= idea.budget %></strong>
              <p><%= idea.notes || 'No notes' %></p>
            </div>
            <form action="/admin/ideas/<%= idea.id %>/status" method="post" class="admin-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <label class="visually-hidden" for="idea-status-<%= idea.id %>">Status</label>
              <select class="form-select" id="idea-status-<%= idea.id %>" name="status">
                <% ['pending', 'done', 'favorite'].forEach((status) => { %>
                  <option value="<%= status %>" <%= idea.status === status ? 'selected' : '' %>>
                    <%= status %>
                  </option>
                <% }) %>
              </select>
              <button type="submit" class="btn btn--outline">Update</button>
            </form>
            <form action="/admin/ideas/<%= idea.id %>/delete" method="post">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn--outline">Delete</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="card admin-section">
      <div class="admin-row">
        <div>
          <h2 class="card__title">Backups</h2>
          <p class="admin-help">ZIP archives include application tables, a manifest, and configured media.</p>
        </div>
        <form action="/admin/backups" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn--primary">Create backup now</button>
        </form>
      </div>
      <ul class="backup-list">
        <% backups.forEach((backup) => { %>
          <li>
            <a href="/admin/backups/<%= backup.name %>"><%= backup.name %></a>
            <span><%= (backup.size / 1024).toFixed(1) %> KB</span>
          </li>
        <% }) %>
        <% if (backups.length === 0) { %><li>No backups available yet.</li><% } %>
      </ul>
    </section>
  </div>
</main>

<%- include('partials/footer') %>
