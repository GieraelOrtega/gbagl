# ─────────────────────────────────────────────────────────
# GBAGL — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to the repo!
# ─────────────────────────────────────────────────────────

# Web server port (Gandi may assign this automatically; 3000 is the local default)
PORT=3000

# Site lock (defaults to 1208 when omitted)
SITE_PASSCODE=1208
# Use a long random value in production so unlock cookies survive app restarts.
PASSCODE_COOKIE_SECRET=replace_with_a_long_random_secret

# ── MySQL / Database ──────────────────────────────────────
# Get these from your Gandi hosting dashboard (Databases section)
DB_HOST=localhost
DB_PORT=3306
DB_USER=gbagl_user
DB_PASSWORD=your_database_password_here
DB_NAME=gbagl_db
