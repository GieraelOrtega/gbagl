# ─────────────────────────────────────────────────────────
# GBAGL — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to the repo!
# ─────────────────────────────────────────────────────────

# Web server port (Gandi may assign this automatically; 3000 is the local default)
PORT=3000

# Required site and admin authentication values. Fill these in locally.
# SITE_PASSCODE must be exactly four digits.
# Production requires a unique site passcode, a 12+ character admin passphrase,
# and a stable random COOKIE_SECRET of at least 32 characters.
SITE_PASSCODE=
ADMIN_PASSWORD=
COOKIE_SECRET=

# Admin session duration in hours
ADMIN_COOKIE_HOURS=12

# ── MySQL / Database ──────────────────────────────────────
# Get these from your Gandi hosting dashboard (Databases section)
# A nonblank DB_SOCKET uses a Unix socket and takes precedence over DB_HOST/DB_PORT.
# Gandi Simple Hosting uses: /srv/run/mysqld/mysqld.sock
DB_SOCKET=
# TCP connection settings are used only when DB_SOCKET is blank.
DB_HOST=localhost
DB_PORT=3306
DB_USER=gbagl_user
DB_PASSWORD=
DB_NAME=gbagl_db

# ── Backups ────────────────────────────────────────────────
# Must not be under public/. Relative paths are resolved from the app root.
BACKUP_DIR=runtime/backups
BACKUP_RETENTION=7
BACKUP_INTERVAL_HOURS=24
# Comma-separated app-relative directories included when present.
# Media paths must not contain or be contained by BACKUP_DIR.
BACKUP_MEDIA_PATHS=public/images,runtime/uploads

# Protected photo uploads. Must remain outside public/. The cap cannot exceed 25 MiB.
UPLOAD_DIR=runtime/uploads
UPLOAD_MAX_BYTES=8388608
