# ─────────────────────────────────────────────────────────
# GBAGL — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to the repo!
# ─────────────────────────────────────────────────────────

# Web server port (Gandi may assign this automatically; 3000 is the local default)
PORT=3000

# ── Anniversary Gate ────────────────────────────────────────
# Set your real anniversary in YYYY-MM-DD format (placeholder shown below).
# Example: 2025-12-08 (keep your real value in private .env only).
ANNIVERSARY_DATE=2025-01-01
# Set a long random secret string for signing unlock cookies.
GATE_SECRET=replace_with_a_long_random_secret

# ── MySQL / Database ──────────────────────────────────────
# Get these from your Gandi hosting dashboard (Databases section)
DB_HOST=localhost
DB_PORT=3306
DB_USER=gbagl_user
DB_PASSWORD=your_database_password_here
DB_NAME=gbagl_db
